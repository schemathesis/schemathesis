SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(operations=[OperationConfig(filter_set=FilterSet(_includes={<Filter: [label_regex=re.compile('.+/users/.+')]>}, _excludes={<Filter: [method=['POST', 'PUT']]>}), parameters={'user_id': ParameterOverride(name='user_id', value='foo', location=None)}), OperationConfig(filter_set=FilterSet(_includes={<Filter: [label='GET /users/']>}, _excludes={<Filter: [filter_function]>}), parameters={'user_id': ParameterOverride(name='user_id', value='foo', location=None)})])))