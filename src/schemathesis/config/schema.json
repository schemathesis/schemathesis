{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "color": {
      "description": "Controls ANSI color output in the CLI. Schemathesis auto-detects color support by default. Set to true to force color output or false to disable it.",
      "type": "boolean"
    },
    "suppress-health-check": {
      "description": "Specifies a list of health checks to disable during test execution.",
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "data_too_large",
          "filter_too_much",
          "too_slow",
          "large_base_example",
          "all"
        ]
      }
    },
    "max-failures": {
      "type": "integer",
      "minimum": 1
    },
    "reports": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "directory": {
          "type": "string"
        },
        "preserve-bytes": {
          "type": "boolean"
        },
        "junit": {
          "$ref": "#/$defs/ReportConfig"
        },
        "har": {
          "$ref": "#/$defs/ReportConfig"
        },
        "vcr": {
          "$ref": "#/$defs/ReportConfig"
        }
      }
    },
    "output": {
      "$ref": "#/$defs/OutputConfig"
    },
    "base-url": {
      "type": "string"
    },
    "parameters": {
      "type": "object"
    },
    "generation": {
      "$ref": "#/$defs/GenerationConfig"
    },
    "operations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/OperationConfig"
      }
    }
  },
  "$defs": {
    "ReportConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        }
      }
    },
    "GenerationConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": [
            "positive",
            "negative",
            "all"
          ]
        },
        "max-examples": {
          "type": "integer"
        },
        "seed": {
          "type": "integer"
        },
        "no-shrink": {
          "type": "boolean"
        },
        "deterministic": {
          "type": "boolean"
        },
        "allow-x00": {
          "type": "boolean"
        },
        "codec": {
          "type": "string"
        },
        "maximize": {
          "anyOf": [
            {
              "enum": [
                "response_time"
              ]
            },
            {
              "type": "array",
              "items": {
                "enum": [
                  "response_time"
                ]
              }
            }
          ]
        },
        "with-security-parameters": {
          "type": "boolean"
        },
        "graphql-allow-null": {
          "type": "boolean"
        },
        "database": {
          "type": "string"
        },
        "unique-inputs": {
          "type": "boolean"
        },
        "fill-missing-examples": {
          "type": "boolean"
        }
      }
    },
    "OutputConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sanitize": {
          "type": "boolean"
        },
        "truncate": {
          "type": "boolean"
        }
      }
    },
    "OperationConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "include-path": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "include-method": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "include-name": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "include-tag": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "include-operation-id": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "include-by": {
          "type": "string"
        },
        "include-path-regex": {
          "type": "string"
        },
        "include-name-regex": {
          "type": "string"
        },
        "include-method-regex": {
          "type": "string"
        },
        "include-tag-regex": {
          "type": "string"
        },
        "include-operation-id-regex": {
          "type": "string"
        },
        "exclude-path": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "exclude-method": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "exclude-name": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "exclude-tag": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "exclude-operation-id": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "exclude-by": {
          "type": "string"
        },
        "exclude-path-regex": {
          "type": "string"
        },
        "exclude-method-regex": {
          "type": "string"
        },
        "exclude-name-regex": {
          "type": "string"
        },
        "exclude-tag-regex": {
          "type": "string"
        },
        "exclude-operation-id-regex": {
          "type": "string"
        },
        "parameters": {
          "type": "object"
        }
      },
      "anyOf": [
        {
          "required": [
            "include-path"
          ]
        },
        {
          "required": [
            "include-method"
          ]
        },
        {
          "required": [
            "include-name"
          ]
        },
        {
          "required": [
            "include-tag"
          ]
        },
        {
          "required": [
            "include-operation-id"
          ]
        },
        {
          "required": [
            "include-by"
          ]
        },
        {
          "required": [
            "include-path-regex"
          ]
        },
        {
          "required": [
            "include-method-regex"
          ]
        },
        {
          "required": [
            "include-name-regex"
          ]
        },
        {
          "required": [
            "include-tag-regex"
          ]
        },
        {
          "required": [
            "include-operation-id-regex"
          ]
        },
        {
          "required": [
            "exclude-path"
          ]
        },
        {
          "required": [
            "exclude-method"
          ]
        },
        {
          "required": [
            "exclude-name"
          ]
        },
        {
          "required": [
            "exclude-tag"
          ]
        },
        {
          "required": [
            "exclude-operation-id"
          ]
        },
        {
          "required": [
            "exclude-by"
          ]
        },
        {
          "required": [
            "exclude-path-regex"
          ]
        },
        {
          "required": [
            "exclude-method-regex"
          ]
        },
        {
          "required": [
            "exclude-name-regex"
          ]
        },
        {
          "required": [
            "exclude-tag-regex"
          ]
        },
        {
          "required": [
            "exclude-operation-id-regex"
          ]
        }
      ]
    }
  }
}
